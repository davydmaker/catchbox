rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      allow write: if request.auth != null
        && request.auth.uid == userId
        // Only allow these 3 fields
        && request.resource.data.keys().hasOnly(['progress', 'settings', 'lastModified'])
        // progress must be a map
        && request.resource.data.progress is map
        // settings must be a map
        && request.resource.data.settings is map
        // lastModified must be a timestamp
        && request.resource.data.lastModified is timestamp
        // Limit document size to 500KB (progress is small, this prevents abuse)
        && request.resource.size() < 512 * 1024;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
